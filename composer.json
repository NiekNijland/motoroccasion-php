{
    "name": "nieknijland/motor-occasion-php",
    "description": "PHP Package to fetch from motoroccasion.nl",
    "keywords": [
        "NiekNijland",
        "motor-occasion-php"
    ],
    "homepage": "https://github.com/nieknijland/motor-occasion-php",
    "license": "MIT",
    "authors": [
        {
            "name": "NiekNijland",
            "email": "niek@nijland.cc",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-dom": "*",
        "guzzlehttp/guzzle": "^7.0",
        "psr/simple-cache": "^3.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.3.2",
        "rector/rector": "^2.0",
        "spatie/ray": "^1.28"
    },
    "autoload": {
        "psr-4": {
            "NiekNijland\\MotorOccasion\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NiekNijland\\MotorOccasion\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --testsuite Unit",
        "test-integration": "vendor/bin/phpunit --testsuite Integration",
        "test-all": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --testsuite Unit --coverage-html build/coverage --coverage-text build/coverage.txt --coverage-clover build/logs/clover.xml --log-junit build/report.junit.xml",
        "format": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=2G",
        "rector": "vendor/bin/rector",
        "rector:dry-run": "vendor/bin/rector process --dry-run",
        "pint": "@php vendor/bin/pint --config https://raw.githubusercontent.com/DIJ-digital/pint-config/main/pint.json",
        "codestyle": [
            "@rector",
            "@pint",
            "@analyse"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
